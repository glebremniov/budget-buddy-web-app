VITE_API_URL=http://localhost:8080

# GitHub token with read:packages scope — required to install @glebremniov/budget-buddy-contracts
# from npm.pkg.github.com. Set this in your shell before running pnpm install:
#   export GITHUB_TOKEN=ghp_...
# Or add it permanently to ~/.zshrc / ~/.zprofile.
# Do NOT set this in .env.local — pnpm reads it from the shell environment, not from .env files.
