VITE_API_URL=http://localhost:8080
VITE_OIDC_ISSUER=
VITE_OIDC_CLIENT_ID=
# Optional: Sentry DSN for error tracking. Leave empty to disable.
# Get your DSN from https://sentry.io → Settings → Projects → <project> → Client Keys.
VITE_SENTRY_DSN=

# GitHub token with read:packages scope — required to install @budget-buddy-org/budget-buddy-contracts
# from npm.pkg.github.com. Set this in your shell before running pnpm install:
#   export GITHUB_TOKEN=ghp_...
# Or add it permanently to ~/.zshrc / ~/.zprofile.
# Do NOT set this in .env.local — pnpm reads it from the shell environment, not from .env files.
