# GitHub Packages registry for @glebremniov scoped packages.
@glebremniov:registry=https://npm.pkg.github.com

# Auth token — read from the GITHUB_TOKEN environment variable.
# pnpm and npm both support ${VAR} interpolation in .npmrc.
#
# Local dev: set GITHUB_TOKEN in your shell (e.g. export GITHUB_TOKEN=$(gh auth token))
# Docker:    passed as a BuildKit secret (never stored in any image layer)
# CI:        GitHub Actions sets GITHUB_TOKEN automatically
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
