{
  "name": "budget-buddy-web-app",
  "private": true,
  "version": "4.6.1",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.33.1"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b",
    "preview": "pnpm run build && wrangler dev",
    "lint": "eslint . && biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "vitest run a11y",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "prepare": "husky",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@budget-buddy-org/budget-buddy-contracts": "^3.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-router-devtools": "^1.166.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-oidc-context": "^3.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@tanstack/router-plugin": "^1.167.32",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "8.0.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.87.0"
  }
}
